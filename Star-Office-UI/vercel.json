{
  "version": 2,
  "buildCommand": "echo 'No build needed'",
  "installCommand": "pip install -r backend/requirements.txt",
  "builds": [
    {
      "src": "backend/app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.9",
        "includeFiles": [
          "backend/**",
          "frontend/**",
          "landing.html",
          "getting-started.html",
          "*.json",
          "*.md"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "backend/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "backend/app.py"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.9"
  }
}
