# PRISM API Configuration
PRISM_URL=https://strykr-prism.up.railway.app

# Telegram Configuration (Optional)
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=your_channel_id_here

# Discord Configuration (Optional)
ENABLE_DISCORD=false
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here

# Alert Configuration
POLL_INTERVAL=30
MIN_MARKET_CAP=5000
MAX_MARKET_CAP=100000
MIN_HOLDERS=10
VOLUME_SPIKE_THRESHOLD=200
BONDING_PROGRESS_THRESHOLD=20

# Star Office UI Integration
OFFICE_UI_URL=http://127.0.0.1:18791
OFFICE_UI_AGENT_NAME=trading-bot
